# --- Ollama (external; http://host.docker.internal:11434 for docker compose, http://localhost:11434 for local api) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=qwen2.5:32b
OLLAMA_EMBED_MODEL=bge-m3
EMBED_DIM=1024
OLLAMA_NUM_PARALLEL=2

# --- Retrieval / RAG ---
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=50
RETRIEVAL_TOP_K=5
RERANK_ENABLED=false
CHAT_HISTORY_TURNS=6
NO_CONTEXT_THRESHOLD=0.35

# --- Stores ---
# POSTGRES_DSN is read by the api; POSTGRES_USER/PASSWORD/DB are read by the
# postgres container. They must agree (the DSN host must be the compose
# service name `postgres` when running in compose).
QDRANT_URL=http://qdrant:6333
POSTGRES_DSN=postgresql+asyncpg://rag:rag@postgres:5432/rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
DATA_DIR=/data/manuals

# --- Auth (set a non-empty value in prod) ---
API_KEY=

# --- App ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Advanced RAG feature flags (all off by default; enable after evaluation) ---
HYBRID_ENABLED=false
SPARSE_MODEL=Qdrant/bm42-all-minilm-l6-v2-attentions
RERANK_ENABLED=false
RERANK_TOP_K=4
QUERY_EXPANSION_ENABLED=false
HYDE_ENABLED=false
NUM_SUBQUERIES=3
CONTEXT_DEDUP_ENABLED=false
TOKEN_ACCURATE_CHUNKING=false
DEDUP_ENABLED=false
EMBED_CACHE_ENABLED=false
EMBED_CACHE_SIZE=1024
TIERED_MODELS_ENABLED=false
OLLAMA_SMALL_LLM_MODEL=qwen2.5:3b
SMALL_MODEL_MAX_WORDS=8
GROUNDING_CHECK_ENABLED=false

